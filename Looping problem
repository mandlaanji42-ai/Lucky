import time

# Set text color to yellow
print("\033[1;33m")

# Loop through rows (1 to 10)
for i in range(1, 11):
    # Pause for 2 seconds before each new row
    time.sleep(2)
    
    # Loop through columns (1 to 10)
    for j in range(1, 11):
        # Print product formatted as 2 digits, followed by a space
        print("{:02d}".format(i * j), end=" ")
        
    # Print a new line after each row
    print()
